{%- endcapture -%}
{% template empty_state %}
  <div class="title title--small lg:title--large mt--2.5">{{ t_all_good }}</div>
  <div class="text--small lg:text--base text--gray">{{ t_all_good_subtitle }}</div>
{% endtemplate %}

{% template title_bar %}
  <div class="title_bar">
    <img
      class="image-stroke image-stroke--large"
      src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}"
      width="28"
      height="28"
      alt="TMB svg logo" />
    <span class="title">{{ title | default: 'TMB' }}</span>
    <span class="instance">
      {% if alert_count and alert_count > 0 %}
        {{ alert_count }} {{ t_active_alerts }}
      {% else %}
        {{ t_line_status }}
      {% endif %}
    </span>
  </div>
{% endtemplate %}