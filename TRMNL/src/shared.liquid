{% assign lines_data = "L1:Hosp. Bellvitge / Fondo|L2:Paral·lel / Badalona PF|L3:Zona Univ. / Trinitat Nova|L4:La Pau / Trinitat Nova|L5:Cornellà / Vall d'Hebron|L9N:La Sagrera / Can Zam|L9S:Zona Univ. / Aeroport T1|L10N:La Sagrera / Gorg|L10S:ZAL Riu Vell / Collblanc|L11:Trinitat Nova / Can Cuiàs|FM:Paral·lel / Parc Montjuïc" | split: "|" %}
{% assign sorted_alerts = data.alerts | sort: "tstamp" | reverse %}

{% assign active_alert_count = 0 %}
{% for alert in sorted_alerts %}
  {% assign e_code = alert.categories.effect_code | default: alert.effect.code %}
  {% assign e_code_prefix = e_code | slice: 0, 2 %}
  {% if e_code_prefix == 'PP' or e_code_prefix == 'NP' %}
    {% assign active_alert_count = active_alert_count | plus: 1 %}
  {% endif %}
{% endfor %}

{% assign user_lang = trmnl.plugin_settings.custom_fields_values.userLanguage | default: "english" | downcase %}
{% case user_lang %}
  {% when "spanish" %}
    {% assign lang_suffix = "Es" %}
    {% assign t_line = "Línea" %}
    {% assign t_destination = "Destino" %}
    {% assign t_status = "Estado" %}
    {% assign t_all_good = "¡Todo bien!" %}
    {% assign t_all_good_subtitle = "Todas las líneas funcionan correctamente. O eso dicen." %}
    {% assign t_active_alerts = "alertas activas" %}
    {% assign t_line_status = "Estado de líneas e incidencias" %}
  {% when "catalan" %}
    {% assign lang_suffix = "Ca" %}
    {% assign t_line = "Línia" %}
    {% assign t_destination = "Destinació" %}
    {% assign t_status = "Estat" %}
    {% assign t_all_good = "Tot bé!" %}
    {% assign t_all_good_subtitle = "Totes les línies funcionen correctament. O això diuen." %}
    {% assign t_active_alerts = "alertes actives" %}
    {% assign t_line_status = "Estat de línies i incidències" %}
  {% else %}
    {% assign lang_suffix = "En" %}
    {% assign t_line = "Line" %}
    {% assign t_destination = "Destination" %}
    {% assign t_status = "Status" %}
    {% assign t_all_good = "All good!" %}
    {% assign t_all_good_subtitle = "Every lane is working properly. Or so they say." %}
    {% assign t_active_alerts = "Active Alerts" %}
    {% assign t_line_status = "Line Status and Outages" %}
{% endcase %}
{% assign text_key = "text" | append: lang_suffix %}
{% assign header_key = "header" | append: lang_suffix %}

{%- capture svg_logo -%}
